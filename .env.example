# Supabase
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_KEY=

# Anthropic
ANTHROPIC_API_KEY=

# Flight APIs
FLIGHTAPI_KEY=

# Email — choose 'smtp' or 'resend'
EMAIL_PROVIDER=resend

# Gmail SMTP (used when EMAIL_PROVIDER=smtp)
GMAIL_USER=
GMAIL_PASS=

# Resend (used when EMAIL_PROVIDER=resend)
RESEND_API_KEY=
RESEND_FROM=YourAppName <alerts@yourdomain.com>

# Optional: deployed frontend URL added to CORS allowlist
FRONTEND_URL=
